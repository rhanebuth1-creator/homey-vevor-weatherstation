  "capabilities": {
    "measure_rain_daily": {
      "type": "number",
      "title": {
        "en": "Daily Rainfall",
        "de": "Tagesniederschlag"
      },
      "units": {
        "en": "mm",
        "de": "mm"
      },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "icon": "/assets/icon.svg",
      "insights": true,
      "decimals": 1
    }
  }
