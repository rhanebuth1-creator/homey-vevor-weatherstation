      {
        "id": "daily_rain_above",
        "title": {
          "en": "Daily rainfall !{{is|is not}} above",
          "de": "Tagesniederschlag !{{ist|ist nicht}} über"
        },
        "titleFormatted": {
          "en": "Daily rainfall !{{is|is not}} above [[rain]] mm",
