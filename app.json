          "en": "Outdoor humidity !{{is|is not}} above [[humidity]] %",
          "de": "Außenluftfeuchtigkeit !{{ist|ist nicht}} über [[humidity]] %"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=vevor_yt60307"
          },
          {
            "name": "humidity",
            "type": "number",
            "placeholder": {
              "en": "%",
              "de": "%"
            }
          }
        ]
      },
      {
        "id": "uv_index_above",
        "title": {
          "en": "UV Index !{{is|is not}} above",
          "de": "UV-Index !{{ist|ist nicht}} über"
        },
        "titleFormatted": {
          "en": "UV Index !{{is|is not}} above [[uv_index]]",
          "de": "UV-Index !{{ist|ist nicht}} über [[uv_index]]"
        },
        "args": [
          {
            "name": "device",
            "type": "device",
            "filter": "driver_id=vevor_yt60307"
          },
          {
            "name": "uv_index",
            "type": "number",
            "placeholder": {
              "en": "UV Index"
            }
          }
        ]
      },
      {
        "id": "luminance_above",
        "title": {
          "en": "Light intensity !{{is|is not}} above",
          "de": "Lichtstärke !{{ist|ist nicht}} über"
        },
        "titleFormatted": {
          "en": "Light intensity !{{is|is not}} above [[luminance]] lux",
